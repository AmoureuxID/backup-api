{
  "version": 2,
  "rewrites": [
    {
      "source": "/comic/:path*",
      "destination": "https://www.sankavollerei.com/comic/:path*"
    },
    {
      "source": "/novel/:path*",
      "destination": "https://www.sankavollerei.com/novel/:path*"
    },
    {
      "source": "/anime/:path*",
      "destination": "https://www.sankavollerei.com/anime/:path*"
    },
    {
      "source": "/moviebox/:path*",
      "destination": "/api/proxy?provider=moviebox&path=:path*"
    },
    {
      "source": "/dramabox/:path*",
      "destination": "/api/proxy?provider=dramabox&path=:path*"
    },
    {
      "source": "/netshort/:path*",
      "destination": "/api/proxy?provider=netshort&path=:path*"
    },
    {
      "source": "/sdrama/:path*",
      "destination": "/api/proxy?provider=sdrama&path=:path*"
    },
    {
      "source": "/docs",
      "destination": "/api/proxy?provider=docs"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/proxy?provider=openapi"
    }
  ]
}
